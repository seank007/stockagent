# stockagent deployment config

# --- Server ---
# Default is 127.0.0.1 (local only). Only use 0.0.0.0 for LAN/remote access,
# and if you do, ALWAYS set WEB_AUTH_TOKEN below.
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_THREADS=8
RUN_TRADING_LOOP=true
AUTO_OPEN_BROWSER=false

# --- Security ---
# If set, the whole dashboard (pages + APIs) requires HTTP Basic auth. Any
# username, password must equal this token. Leave empty only for paper/public
# demos. The live-trading server MUST set a strong value.
WEB_AUTH_TOKEN=
# Per-order safety ceiling for manual dashboard orders (KRW). Blocks fat-finger
# / unauthorized large orders. Raise if you intend larger manual trades.
MAX_MANUAL_ORDER_KRW=1000000

# --- Alerts (optional, Telegram) ---
# Fills, pause/resume, and errors are pushed here when both are set.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Trading safety ---
# Default should stay true until you have verified the deployment.
DRY_RUN=true
# Live trading requires both DRY_RUN=false and ALLOW_LIVE_TRADING=true.
ALLOW_LIVE_TRADING=false

# --- Upbit ---
UPBIT_ACCESS_KEY=your-upbit-access-key
UPBIT_SECRET_KEY=your-upbit-secret-key

# --- AI provider ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=

# Optional model overrides
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o
CLAUDE_MODEL=claude-opus-4-8

# --- Strategy ---
TICKERS=KRW-BTC,KRW-SOL
INTERVAL_SECONDS=600
CANDLE_INTERVAL=minute60
CANDLE_COUNT=50
MAX_ORDER_KRW=10000
MIN_ORDER_KRW=5000
MAX_DAILY_LOSS_KRW=30000
MIN_CONFIDENCE=0.6

# --- Multi-user (여러 사용자 계정) ---
# 거래소 시크릿 암호화 마스터 키. `python -c "from multiuser.vault import generate_master_key as g; print(g())"`
# 로 생성해서 주입. 운영 필수(유실 시 저장된 키 복호화 불가). 비우면 개발용 파일이 자동 생성됨.
MULTIUSER_MASTER_KEY=
# 멀티유저 DB 경로(기본 ./multiuser.db, 단일 봇 DB와 분리)
MULTIUSER_DB_PATH=
# 세션 쿠키 secure 플래그. HTTPS 운영은 true, 로컬 http 개발만 false.
SESSION_COOKIE_SECURE=true
# 관리자 이메일은 일반 가입이 차단됩니다. 32자 이상의 별도 토큰을 설정한 뒤
# `python scripts/create_admin.py admin@example.com`을 신뢰된 서버 셸에서 실행하세요.
ADMIN_EMAILS=
ADMIN_BOOTSTRAP_TOKEN=

# --- Performance ---
MAX_DECISION_WORKERS=4
AI_PROVIDER_COOLDOWN_SECONDS=600
AI_HTTP_TIMEOUT_SECONDS=12
STATE_HISTORY_LIMIT=80
STATE_REASON_MAX_CHARS=260
API_REASON_MAX_CHARS=360
