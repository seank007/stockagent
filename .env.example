# stockagent deployment config

# --- Server ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_THREADS=8
RUN_TRADING_LOOP=true
AUTO_OPEN_BROWSER=false

# --- Trading safety ---
# Default should stay true until you have verified the deployment.
DRY_RUN=true
# Live trading requires both DRY_RUN=false and ALLOW_LIVE_TRADING=true.
ALLOW_LIVE_TRADING=false

# --- Upbit ---
UPBIT_ACCESS_KEY=your-upbit-access-key
UPBIT_SECRET_KEY=your-upbit-secret-key

# --- AI provider ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=

# Optional model overrides
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o
CLAUDE_MODEL=claude-opus-4-8

# --- Strategy ---
TICKERS=KRW-BTC,KRW-SOL
INTERVAL_SECONDS=600
CANDLE_INTERVAL=minute60
CANDLE_COUNT=50
MAX_ORDER_KRW=10000
MIN_ORDER_KRW=5000
MAX_DAILY_LOSS_KRW=30000
MIN_CONFIDENCE=0.6

# --- Performance ---
MAX_DECISION_WORKERS=4
AI_PROVIDER_COOLDOWN_SECONDS=600
AI_HTTP_TIMEOUT_SECONDS=12
STATE_HISTORY_LIMIT=80
STATE_REASON_MAX_CHARS=260
API_REASON_MAX_CHARS=360
